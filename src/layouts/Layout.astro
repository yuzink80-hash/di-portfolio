---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · DI Portfolio</title>
    <meta name="description" content="영상 종편 / 컬러 그레이딩(DI) 작업 포트폴리오" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="/" class="site-header__logo">DI<span>·</span>PORTFOLIO</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} 유진. All rights reserved.</p>
    </footer>
  </body>
</html>
